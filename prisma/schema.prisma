// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ResearchAssistant {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  faculty   String   @default("DZ")
  department String  @default("GMIM")
  totalPoints Int     @default(0)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  role      String   @default("user")
  password  String?
  passwordHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]
  permanentDuties PermanentDuty[]
  pendingDutyChanges PendingDutyChange[]
  examAssignments ExamSupervisor[]
  weeklySchedule WeeklySchedule[]
  notifications Notification[]
  announcements Announcement[]
  announcementComments AnnouncementComment[]
  sessions  Session[]
}

model PointCategory {
  id          String   @id @default(cuid())
  name        String
  points      Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  number      Int
  description String
  hoursWorked String?
  date        DateTime
  points      Int
  status      String   @default("pending")
  source      String   @default("external")
  assignedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assistantId String
  assistant   ResearchAssistant @relation(fields: [assistantId], references: [id])
  categoryId  String?
  category    PointCategory? @relation(fields: [categoryId], references: [id])

  @@index([assistantId, status])
  @@index([date])
}

model PermanentDuty {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assistantId String
  assistant   ResearchAssistant @relation(fields: [assistantId], references: [id])
}

model Exam {
  id            String   @id @default(cuid())
  courseCode    String
  courseName    String
  instructor    String
  date          DateTime
  day           String
  timeSlot      String
  department    String   @default("GMIM")
  classroom     String?
  requiredSupervisors Int  @default(1)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supervisors  ExamSupervisor[]
}

model ExamSupervisor {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  examId      String
  exam        Exam @relation(fields: [examId], references: [id])
  assistantId String
  assistant   ResearchAssistant @relation(fields: [assistantId], references: [id])

  @@unique([examId, assistantId])
}

model WeeklySchedule {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  timeSlot    String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assistantId String
  assistant   ResearchAssistant @relation(fields: [assistantId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("info")
  isRead      Boolean  @default(false)
  relatedId   String?
  createdAt   DateTime @default(now())

  assistantId String
  assistant   ResearchAssistant @relation(fields: [assistantId], references: [id])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  department  String   @default("GMIM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String
  author      ResearchAssistant @relation(fields: [authorId], references: [id])

  comments    AnnouncementComment[]
}

model AnnouncementComment {
  id          String   @id @default(cuid())
  content     String
  createdAt   DateTime @default(now())

  announcementId String
  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  authorId    String
  author      ResearchAssistant @relation(fields: [authorId], references: [id])
}

model PendingDutyChange {
  id          String   @id @default(cuid())
  changeType  String   // "add", "edit", "delete"
  dutyName    String   // new name (for add/edit) or existing name (for delete)
  description String?
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assistantId String
  assistant   ResearchAssistant @relation(fields: [assistantId], references: [id])
  dutyId      String?  // existing duty ID for edit/delete
  submittedBy String?  // who submitted this change
}

model ImportLog {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String   @default("xlsx")
  recordCount Int      @default(0)
  status      String   @default("processing")
  error       String?
  createdAt   DateTime @default(now())
}

model AcademicPeriod {
  id          String   @id @default(cuid())
  name        String
  department  String
  startsAt    DateTime
  endsAt      DateTime?
  status      String   @default("open")
  closedAt    DateTime?
  closedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([department, name])
  @@index([department, status])
}

model ImportBatch {
  id          String   @id @default(cuid())
  fileName    String
  fileHash    String
  importType  String
  department  String
  status      String   @default("previewed")
  createdById String
  committedAt DateTime?
  rolledBackAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rows        ImportBatchRow[]

  @@unique([fileHash, importType, department])
  @@index([department, status])
}

model ImportBatchRow {
  id          String   @id @default(cuid())
  batchId     String
  rowNumber   Int
  status      String
  message     String?
  raw         Json
  taskId      String?
  createdAt   DateTime @default(now())

  batch       ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  @@index([batchId])
  @@index([taskId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   ResearchAssistant @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
